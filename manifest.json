{
    "manifest_version": 3,
    "name": "KeyEZ",
    "version": "1.0",
    "description": "Khmer Spelling Checker & Grammar is a Khmer writing assistant for the web.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://keyez.tech/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "popup.js"
            ],
            "css": [
                "popup.css"
            ],
            "all_frames": true
        }
    ],
    "action": {
        "default_popup": "settings.html",
        "default_icon": {
            "16": "icon.png",
            "48": "icon.png",
            "128": "icon.png"
        }
    },
    "icons": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icon.png",
                "LogK.png"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}